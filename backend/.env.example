# Copy to .env and fill in as needed. All values have safe defaults in app/config.py.

# --- Groq API key for Tier 3 explainability summaries ---
# If unset, the system falls back to a deterministic template summary.
# Get a free key at https://console.groq.com
GROQ_API_KEY=

# --- CORS: where the Next.js frontend is served from ---
FRONTEND_ORIGIN=http://localhost:3000
